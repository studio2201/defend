<?xml version="1.0"?>
<Container version="2">
  <Name>defend</Name>
  <Repository>ghcr.io/studio2201/defend:latest</Repository>
  <Registry>https://ghcr.io/studio2201/defend</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/studio2201/defend/issues</Support>
  <Project>https://github.com/studio2201/defend</Project>
  <Overview>Interactive self-hosted security playground and firewall defense simulator built in Rust.</Overview>
  <Category>Game:Arcade Network:Web</Category>
  <WebUI>http://[IP]:[PORT:4504]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/studio2201/unraid-templates/main/templates/defend.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/studio2201/unraid-templates/main/icons/defend.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Description>Interactive self-hosted security playground and firewall defense simulator built in Rust.</Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>4504</HostPort>
        <ContainerPort>4504</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/defend</HostDir>
      <ContainerDir>/config</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>4504</Value>
      <Name>PORT</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>/config</Value>
      <Name>DATA_DIR</Name>
      <Mode/>
    </Variable>
  </Environment>
  <Labels/>
  <Config Name="Web UI Port" Target="4504" Default="4504" Mode="tcp" Description="HTTP Web Interface Port" Type="Port" Display="always" Required="true" Mask="false">4504</Config>
  <Config Name="App Storage Directory" Target="/config" Default="/mnt/user/appdata/defend" Mode="rw" Description="Persistent data and configuration directory" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/defend</Config>
</Container>
